{
  "name": "@desk/viewer",
  "version": "0.1.0",
  "description": "The Desk viewer — the operator's window into Desk. Renders artifacts, surfaces comments, and runs the realtime channel.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run build:harness && vite",
    "build": "bun run build:harness && tsc --noEmit && vite build",
    "build:harness": "bun build ./src/harness/main.tsx --outfile public/custom-harness.js --format iife --minify",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@desk/anchor-geometry": "workspace:*",
    "@desk/plugin-sdk": "workspace:*",
    "@desk/plugins-builtin": "workspace:*",
    "@desk/types": "workspace:*",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@terrastruct/d2": "^0.1.33",
    "@viz-js/viz": "^3.27.0",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.11",
    "katex": "^0.16.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shiki": "^1.24.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^20.9.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
